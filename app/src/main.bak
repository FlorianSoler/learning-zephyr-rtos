#include <zephyr/kernel.h>
#include <zephyr/sys/printk.h>
#include <zephyr/drivers/gpio.h>

#include <zephyr/bluetooth/bluetooth.h>
#include <zephyr/bluetooth/conn.h>
#include <zephyr/bluetooth/hci.h>
#include <zephyr/settings/settings.h>

/* ---------------- ONBOARD LED ---------------- */

#define LED_NODE DT_ALIAS(led0)

#if !DT_NODE_HAS_STATUS(LED_NODE, okay)
#error "led0 not defined in devicetree for this board"
#endif

static const struct gpio_dt_spec led =
    GPIO_DT_SPEC_GET(LED_NODE, gpios);

/* ---------------- STATE ---------------- */

static struct bt_conn *default_conn;

/* ---------------- FORWARD ---------------- */

static void start_scan(void);

/* ---------------- SCAN CALLBACK ---------------- */

static void device_found(const bt_addr_le_t *addr,
                         int8_t rssi,
                         uint8_t type,
                         struct net_buf_simple *ad)
{
    char addr_str[BT_ADDR_LE_STR_LEN];
    int err;

    if (default_conn) {
        return;
    }

    /* RSSI filter (distance gate) */
    if (rssi < -75) {
        return;
    }

    bt_addr_le_to_str(addr, addr_str, sizeof(addr_str));
    printk("Device found %s (RSSI %d)\n", addr_str, rssi);

    bt_le_scan_stop();

    err = bt_conn_le_create(addr,
                            BT_CONN_LE_CREATE_CONN,
                            BT_LE_CONN_PARAM_DEFAULT,
                            &default_conn);

    if (err) {
        printk("Connection failed (%d)\n", err);
        start_scan();
    }
}

/* ---------------- SCAN START ---------------- */

static void start_scan(void)
{
    int err;

    struct bt_le_scan_param scan_param = {
        .type     = BT_LE_SCAN_TYPE_ACTIVE,
        .options  = BT_LE_SCAN_OPT_NONE,
        .interval = BT_GAP_SCAN_FAST_INTERVAL,
        .window   = BT_GAP_SCAN_FAST_WINDOW,
    };

    err = bt_le_scan_start(&scan_param, device_found);
    if (err) {
        printk("Scan start failed (%d)\n", err);
        return;
    }

    printk("Scanning for BLE devices...\n");
}

/* ---------------- CONNECTION CALLBACKS ---------------- */

static void connected(struct bt_conn *conn, uint8_t err)
{
    if (err) {
        printk("Connection failed (%u)\n", err);

        if (default_conn) {
            bt_conn_unref(default_conn);
            default_conn = NULL;
        }

        start_scan();
        return;
    }

    printk("Connected\n");

    /* request encryption */
    bt_conn_set_security(conn, BT_SECURITY_L2);
}

static void disconnected(struct bt_conn *conn, uint8_t reason)
{
    printk("Disconnected (%u)\n", reason);

    if (default_conn) {
        bt_conn_unref(default_conn);
        default_conn = NULL;
    }

    /* LED OFF on disconnect */
    gpio_pin_set_dt(&led, 0);

    start_scan();
}

static void security_changed(struct bt_conn *conn,
                              bt_security_t level,
                              enum bt_security_err err)
{
    if (err || level < BT_SECURITY_L2) {
        printk("Security failed (%d)\n", err);
        bt_conn_disconnect(conn, BT_HCI_ERR_AUTH_FAIL);
        return;
    }

    printk("Secure connection established (level %d)\n", level);

    /* LED ON = authenticated device */
    gpio_pin_set_dt(&led, 1);
}

/* ---------------- CALLBACK STRUCT ---------------- */

BT_CONN_CB_DEFINE(conn_callbacks) = {
    .connected = connected,
    .disconnected = disconnected,
    .security_changed = security_changed,
};

/* ---------------- MAIN ---------------- */

int main(void)
{
    int err;

    printk("Starting BLE proximity LED system...\n");

    /* LED init */
    if (!gpio_is_ready_dt(&led)) {
        printk("LED not ready\n");
        return 0;
    }

    gpio_pin_configure_dt(&led, GPIO_OUTPUT_INACTIVE);

    /* BLE init */
    err = bt_enable(NULL);
    if (err) {
        printk("Bluetooth init failed (%d)\n", err);
        return 0;
    }

    /* load bonding keys */
    if (IS_ENABLED(CONFIG_SETTINGS)) {
        settings_load();
    }

    start_scan();

    return 0;
}